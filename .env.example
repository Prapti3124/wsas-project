# WSAS Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to Git!

# Flask
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_DEBUG=true

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database
# SQLite (development):
DATABASE_URL=sqlite:///wsas.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@host:5432/wsas_db

# Google OAuth
GOOGLE_CLIENT_ID=your_google_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_secret

# Email / SMTP (for OTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_DEFAULT_SENDER="WSAS Safety" <your_email@gmail.com>

# Twilio (SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# CORS
CORS_ORIGINS=*
# (comma-separated origins)
# CORS_ORIGINS=http://localhost:5000,https://your-domain.com
