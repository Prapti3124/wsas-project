# WSAS Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to Git!

# Flask
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_DEBUG=true

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production

# Database
# SQLite (development):
DATABASE_URL=sqlite:///wsas.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@host:5432/wsas_db

# Twilio (SMS alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5000,https://your-domain.com
